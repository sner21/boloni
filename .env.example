# 列出本地开发和部署所需的环境变量示例。

# PostgreSQL 数据库连接地址。
DATABASE_URL=postgres://postgres:postgres@localhost:5432/supply_base
# AI provider，默认 mock 可无密钥演示。
AI_PROVIDER=mock
# 火山方舟 API Key，mock 模式可留空。
ARK_API_KEY=
# 火山方舟 OpenAI 兼容 API 地址。
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 火山方舟控制台已开通的模型 ID。
ARK_MODEL=doubao-lite-32k
